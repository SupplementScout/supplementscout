{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "supplementscout://retailer-snapshot/phase-0/v1",
  "schema_version": 1,
  "closed_objects": true,
  "string_rules": {
    "identifiers": "external IDs, database bigint IDs, GTIN, SKU, fingerprints and decimal money/quantity values remain strings",
    "decimals": "^-?(0|[1-9][0-9]*)(\\.[0-9]+)?$; no exponent, NaN, Infinity or negative zero",
    "timestamps": "UTC RFC3339 with milliseconds; excluded from plan fingerprints unless explicitly marked observed evidence",
    "nulls": "missing optional property is different from required property with null; empty strings forbidden except raw source values"
  },
  "$defs": {
    "sha256": {"type":"string","pattern":"^[0-9a-f]{64}$"},
    "uuid": {"type":"string","format":"uuid"},
    "timestamp": {"type":"string","format":"date-time","maxLength":35},
    "shortString": {"type":"string","minLength":1,"maxLength":255},
    "longString": {"type":"string","maxLength":20000},
    "nullableShortString": {"type":["string","null"],"maxLength":255},
    "nullableUrl": {"type":["string","null"],"format":"uri","maxLength":2048},
    "idString": {"type":"string","minLength":1,"maxLength":128},
    "nullableIdString": {"type":["string","null"],"maxLength":128},
    "decimalString": {"type":"string","pattern":"^(0|[1-9][0-9]*)(\\.[0-9]+)?$","maxLength":40},
    "nullableDecimalString": {"type":["string","null"],"pattern":"^(0|[1-9][0-9]*)(\\.[0-9]+)?$","maxLength":40},
    "PrimaryStatus": {"enum":["SAFE_EXISTING_VARIANT","SAFE_EXISTING_PRODUCT_MISSING_VARIANT","SAFE_NEW_CANONICAL_PRODUCT","SAFE_NEW_CANONICAL_FAMILY_WITH_VARIANTS","AMBIGUOUS","BLOCKED","OUT_OF_STOCK","DUPLICATE_SOURCE_IDENTITY","DEFERRED_POLICY"]},
    "ProposedAction": {"enum":["NOOP","UPDATE_OFFER","CREATE_MAPPING_AND_OFFER","CREATE_CANONICAL_VARIANT","CREATE_CANONICAL_PRODUCT","CREATE_CANONICAL_FAMILY","QUARANTINE","SKIP_OOS","SKIP_POLICY","BLOCK"]},
    "ExistingOfferAction": {"enum":["VERIFY_NO_CHANGE","UPDATE_PRICE","UPDATE_STOCK","UPDATE_PRICE_AND_STOCK","UPDATE_URL","UPDATE_PRICE_STOCK_URL","BLOCK_IDENTITY_DRIFT","BLOCK_SOURCE_ANOMALY"]},
    "MixedBatchDeltas": {"type":"object","additionalProperties":false,"required":["row_count_deltas","logical_field_deltas"],"properties":{"row_count_deltas":{"type":"object","additionalProperties":false,"required":["products","product_variants","retailer_products","offers","price_history"],"properties":{"products":{"type":"integer","minimum":0},"product_variants":{"type":"integer","minimum":0},"retailer_products":{"type":"integer","minimum":0},"offers":{"type":"integer","minimum":0},"price_history":{"type":"integer","minimum":0}}},"logical_field_deltas":{"type":"object","additionalProperties":false,"required":["offer_price_updates","offer_shipping_updates","offer_total_updates","offer_stock_updates","offer_url_updates","mapping_url_updates","mapping_updated_at_updates","last_checked_at_updates"],"properties":{"offer_price_updates":{"type":"integer","minimum":0},"offer_shipping_updates":{"type":"integer","minimum":0},"offer_total_updates":{"type":"integer","minimum":0},"offer_stock_updates":{"type":"integer","minimum":0},"offer_url_updates":{"type":"integer","minimum":0},"mapping_url_updates":{"type":"integer","minimum":0},"mapping_updated_at_updates":{"type":"integer","minimum":0},"last_checked_at_updates":{"type":"integer","minimum":0}}}}},
    "ApprovalLevel": {"enum":["AUTO_LOW_RISK","PARENT_APPROVAL","CHILD_APPROVAL","MANUAL_REVIEW","FORBIDDEN"]},
    "Confidence": {"enum":["VERY_HIGH","HIGH","MEDIUM","LOW","NONE"]},
    "RowAction": {"enum":["CREATE","REUSE","UPDATE","NOOP","SKIP","BLOCK"]},
    "ChildStatus": {"enum":["PLANNED","APPROVED","APPLYING","APPLIED","FAILED","ROLLED_BACK","EXPIRED","SUPERSEDED"]},

    "SourceFile": {"type":"object","additionalProperties":false,"required":["file_id","name","media_type","byte_length","sha256","role"],"properties":{"file_id":{"$ref":"#/$defs/idString"},"name":{"$ref":"#/$defs/shortString"},"media_type":{"$ref":"#/$defs/shortString"},"byte_length":{"type":"integer","minimum":1},"sha256":{"$ref":"#/$defs/sha256"},"role":{"enum":["PRIMARY","ENRICHMENT","PAGINATION_MANIFEST","POLICY"]}}},
    "ShippingPolicy": {"type":"object","additionalProperties":false,"required":["status","currency","rules","config_sha256"],"properties":{"status":{"enum":["VERIFIED","UNVERIFIED","NOT_APPLICABLE"]},"currency":{"const":"GBP"},"rules":{"type":"array","maxItems":20,"items":{"type":"object"}},"config_sha256":{"$ref":"#/$defs/sha256"}}},
    "AffiliatePolicy": {"type":"object","additionalProperties":false,"required":["status","network","merchant_id","url_template","config_sha256"],"properties":{"status":{"enum":["CONFIGURED","NOT_CONFIGURED","BLOCKED"]},"network":{"$ref":"#/$defs/nullableShortString"},"merchant_id":{"$ref":"#/$defs/nullableShortString"},"url_template":{"$ref":"#/$defs/nullableUrl"},"config_sha256":{"$ref":"#/$defs/sha256"}}},
    "RawSourceValues": {"type":"object","additionalProperties":true,"maxProperties":100,"description":"Lossless adapter-selected raw values. Values are string, boolean, null, arrays or closed source objects; numeric source IDs and money are converted to strings."},
    "NormalizedSourceValues": {"type":"object","additionalProperties":false,"required":["product_title","variant_title","brand","category","product_format","flavour","size_value","size_unit","unit_count","unit_type","servings","pack_count"],"properties":{"product_title":{"$ref":"#/$defs/shortString"},"variant_title":{"$ref":"#/$defs/shortString"},"brand":{"$ref":"#/$defs/nullableShortString"},"category":{"$ref":"#/$defs/nullableShortString"},"product_format":{"$ref":"#/$defs/nullableShortString"},"flavour":{"$ref":"#/$defs/nullableShortString"},"size_value":{"$ref":"#/$defs/nullableDecimalString"},"size_unit":{"type":["string","null"],"enum":["g","ml","iu",null]},"unit_count":{"$ref":"#/$defs/nullableDecimalString"},"unit_type":{"$ref":"#/$defs/nullableShortString"},"servings":{"$ref":"#/$defs/nullableDecimalString"},"pack_count":{"$ref":"#/$defs/nullableDecimalString"}}},
    "SourceRecord": {"type":"object","additionalProperties":false,"required":["source_record_id","immutable_source_identity","raw","normalized","external_product_id","external_variant_id","sku","gtin","product_url","variant_url","image_url","price","compare_at_price","in_stock","title","vendor","product_type","options","grams","unit_count","unit_type","servings","pack_count","category_evidence","source_created_at","source_updated_at","raw_row_fingerprint"],"properties":{"source_record_id":{"$ref":"#/$defs/idString"},"immutable_source_identity":{"type":"string","maxLength":512},"raw":{"$ref":"#/$defs/RawSourceValues"},"normalized":{"$ref":"#/$defs/NormalizedSourceValues"},"external_product_id":{"$ref":"#/$defs/idString"},"external_variant_id":{"$ref":"#/$defs/idString"},"sku":{"$ref":"#/$defs/nullableShortString"},"gtin":{"type":["string","null"],"maxLength":32},"product_url":{"type":"string","format":"uri","maxLength":2048},"variant_url":{"type":"string","format":"uri","maxLength":2048},"image_url":{"$ref":"#/$defs/nullableUrl"},"price":{"$ref":"#/$defs/decimalString"},"compare_at_price":{"$ref":"#/$defs/nullableDecimalString"},"in_stock":{"type":"boolean"},"title":{"type":"string","minLength":1,"maxLength":500},"vendor":{"$ref":"#/$defs/nullableShortString"},"product_type":{"$ref":"#/$defs/nullableShortString"},"options":{"type":"object","maxProperties":10,"additionalProperties":{"type":"string","maxLength":255}},"grams":{"$ref":"#/$defs/nullableDecimalString"},"unit_count":{"$ref":"#/$defs/nullableDecimalString"},"unit_type":{"$ref":"#/$defs/nullableShortString"},"servings":{"$ref":"#/$defs/nullableDecimalString"},"pack_count":{"$ref":"#/$defs/nullableDecimalString"},"category_evidence":{"type":"array","maxItems":20,"items":{"type":"string","maxLength":255}},"source_created_at":{"anyOf":[{"$ref":"#/$defs/timestamp"},{"type":"null"}]},"source_updated_at":{"anyOf":[{"$ref":"#/$defs/timestamp"},{"type":"null"}]},"raw_row_fingerprint":{"$ref":"#/$defs/sha256"}}},

    "RetailerSourceSnapshot": {"type":"object","additionalProperties":false,"required":["schema_version","snapshot_id","retailer_id","retailer_slug","retailer_name","source_type","source_origin","source_files","source_sha256","source_schema_fingerprint","adapter_name","adapter_version","adapter_commit","adapter_sha256","captured_at","source_updated_at","currency","country","shipping_policy","affiliate_policy","records","record_count","product_count","variant_count","in_stock_count","out_of_stock_count","warnings","provenance"],"properties":{"schema_version":{"const":1},"snapshot_id":{"$ref":"#/$defs/uuid"},"retailer_id":{"$ref":"#/$defs/idString"},"retailer_slug":{"type":"string","pattern":"^[a-z0-9]+(?:-[a-z0-9]+)*$","maxLength":120},"retailer_name":{"$ref":"#/$defs/shortString"},"source_type":{"enum":["SHOPIFY_PUBLIC_JSON","SHOPIFY_CSV_JSON","CSV","AFFILIATE_FEED","DIRECT_FEED"]},"source_origin":{"type":"string","format":"uri","maxLength":2048},"source_files":{"type":"array","minItems":1,"maxItems":20,"items":{"$ref":"#/$defs/SourceFile"}},"source_sha256":{"$ref":"#/$defs/sha256"},"source_schema_fingerprint":{"$ref":"#/$defs/sha256"},"adapter_name":{"$ref":"#/$defs/shortString"},"adapter_version":{"type":"string","maxLength":50},"adapter_commit":{"type":"string","pattern":"^[0-9a-f]{40}$"},"adapter_sha256":{"$ref":"#/$defs/sha256"},"captured_at":{"$ref":"#/$defs/timestamp"},"source_updated_at":{"anyOf":[{"$ref":"#/$defs/timestamp"},{"type":"null"}]},"currency":{"const":"GBP"},"country":{"const":"GB"},"shipping_policy":{"$ref":"#/$defs/ShippingPolicy"},"affiliate_policy":{"$ref":"#/$defs/AffiliatePolicy"},"records":{"type":"array","items":{"$ref":"#/$defs/SourceRecord"}},"record_count":{"type":"integer","minimum":0},"product_count":{"type":"integer","minimum":0},"variant_count":{"type":"integer","minimum":0},"in_stock_count":{"type":"integer","minimum":0},"out_of_stock_count":{"type":"integer","minimum":0},"warnings":{"type":"array","maxItems":10000,"items":{"type"