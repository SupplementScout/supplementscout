    "ClassifiedRecord": {"type":"object","additionalProperties":false,"required":["source_record_id","primary_status","secondary_statuses","confidence","reason_codes","evidence","canonical_product_candidates","canonical_variant_candidates","selected_canonical_product","selected_canonical_variant","proposed_action","approval_level","dependency_group","rollback_group","quarantine_required","review_required","record_fingerprint"],"properties":{"source_record_id":{"$ref":"#/$defs/idString"},"primary_status":{"$ref":"#/$defs/PrimaryStatus"},"secondary_statuses":{"type":"array","uniqueItems":true,"items":{"$ref":"#/$defs/PrimaryStatus"}},"confidence":{"$ref":"#/$defs/Confidence"},"reason_codes":{"type":"array","minItems":1,"uniqueItems":true,"items":{"type":"string"}},"evidence":{"type":"object"},"canonical_product_candidates":{"type":"array","items":{"type":"object"}},"canonical_variant_candidates":{"type":"array","items":{"type":"object"}},"selected_canonical_product":{"type":["object","null"]},"selected_canonical_variant":{"type":["object","null"]},"proposed_action":{"$ref":"#/$defs/ProposedAction"},"approval_level":{"$ref":"#/$defs/ApprovalLevel"},"dependency_group":{"type":"string","maxLength":512},"rollback_group":{"type":"string","maxLength":512},"quarantine_required":{"type":"boolean"},"review_required":{"type":"boolean"},"record_fingerprint":{"$ref":"#/$defs/sha256"}}},
